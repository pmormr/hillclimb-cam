# hillclimb-cam node config — installed as /etc/default/cam-stream-<CAM_PATH>.
# install.sh generates this for you; this file documents every knob for a manual
# install or a tweak. One env file per camera path (one camera per Pi).

# --- required ---
# Camera device. Prefer the stable USB-port path so it survives video-node
# renumbering across reboots (find yours with ./bin/probe-camera.sh):
CAM_DEVICE=/dev/v4l/by-path/platform-xhci-hcd.0-usb-0:1.1:1.0-video-index0
# MediaMTX path to publish to. Must exist on the hub and be unused. On the van
# hub cam1 is picam1 — a second Pi uses cam2, then cam3, cam4.
CAM_PATH=cam2
# The hub's IP (the van's MediaMTX). Its SRT port :8890 must be reachable.
HUB_HOST=192.168.42.178

# --- capture / encode ---
# Camera pixel format: yuyv422 (uncompressed, common cheap webcams) | mjpeg | h264.
CAM_INPUT_FORMAT=yuyv422
# Encoder: auto | h264_v4l2m2m (Pi HW) | libx264 (software) | copy (h264 cams).
# auto: h264 input -> copy; else HW encoder if /dev/video11 exists; else libx264.
CAM_ENCODER=auto
CAM_W=1280
CAM_H=720
CAM_FPS=10
CAM_BITRATE=2500k

# --- transport / startup (defaults are fine for most) ---
HUB_PORT=8890          # MediaMTX SRT ingest port
SRT_LATENCY=200        # SRT receiver buffer (ms): higher = more loss tolerance, more delay
HUB_WAIT=30            # cold boot: wait up to N s for the hub before starting ffmpeg
